{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "incremental": true,
  "mutate": ["src/**/*.ts", "src/**/*.tsx", "!src/**/*.{test,spec}.{ts,tsx}"],
  "reporters": ["clear-text", "progress"],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  }
}
