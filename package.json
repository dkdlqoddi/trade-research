{
  "name": "trade-research",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run --reporter=dot -t \"^(?!.*@quarantine)\"",
    "test:e2e": "playwright test --retries=1 --grep-invert @quarantine"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/eslintrc": "^3.3.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.52.0",
    "@size-limit/file": "^11.2.0",
    "@stryker-mutator/core": "^9.0.0",
    "@stryker-mutator/vitest-runner": "^9.0.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.0",
    "fast-check": "^4.1.0",
    "prettier": "^3.5.0",
    "size-limit": "^11.2.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/**/*.js",
      "limit": "350 kB"
    }
  ],
  "allowScripts": {
    "esbuild@0.27.7": true,
    "better-sqlite3@12.10.0": true
  }
}
